# ---- HangOut backend environment ----
# Copy this file to `.env` and fill in real values for local development.
# On a hosting platform (Render/Railway), set these as environment variables.

# MongoDB connection string (required)
mongoUrl=mongodb+srv://<user>:<password>@<cluster>/<database>

# Port the server listens on (platforms set this automatically)
port=8080

# Secret used to sign JWT tokens (required) — use a long random string
key=change-me-to-a-long-random-secret

# Set to "production" on your host to enable Secure cookies (HTTPS only).
# NODE_ENV=production

# Comma-separated allowed CORS origins. Leave unset for same-origin use
# (the backend serves the frontend). Lock to your domain in production.
# ALLOWED_ORIGINS=https://spry-smash-650.onrender.com

# Redis is OPTIONAL. If omitted, an in-memory token store is used
# (fine for a single-instance deployment). Set this to use real Redis.
# REDIS_URL=redis://default:<password>@<host>:<port>

# Comma-separated emails treated as admins (see the "Admin" nav link + panel).
# Any listed user is promoted to role "admin" on login. Defaults to the
# project's documented admin accounts if unset.
# ADMIN_EMAILS=himanshu@gmail.com,parth@gmail.com

# ---- OAuth (optional — routes are currently disabled in index.js) ----
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
